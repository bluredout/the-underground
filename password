<!DOCTYPE html>
<html>
<head>
<title>The Underground</title>
<link rel="stylesheet" href="style.css">
</head>

<body class="gate">

<h1>THE UNDERGROUND</h1>
<p>AUTHORIZED PLAYERS ONLY</p>

<input type="password" id="pass" placeholder="Enter Code">
<button onclick="login()">ENTER</button>

<p id="msg"></p>

<script>
function login(){

let password = "underground";

let input = document.getElementById("pass").value;

if(input === password){
window.location = "arcade.html";
}else{
document.getElementById("msg").innerHTML="ACCESS DENIED";
}

}
</script>

</body>
</html>
